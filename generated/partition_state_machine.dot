digraph fbvbs_partition_fsm {
  rankdir=LR;
  node [shape=ellipse, fontname="Helvetica"];
  START -> "Created" [label="PARTITION_CREATE または VM_CREATE"];
  "Created" -> "Measured" [label="PARTITION_MEASURE"];
  "Measured" -> "Loaded" [label="PARTITION_LOAD_IMAGE"];
  "Loaded" -> "Runnable" [label="PARTITION_START"];
  "Runnable" -> "Running" [label="スケジューラ選択"];
  "Running" -> "Quiesced" [label="PARTITION_QUIESCE"];
  "Runnable" -> "Quiesced" [label="PARTITION_QUIESCE"];
  "Quiesced" -> "Runnable" [label="PARTITION_RESUME"];
  "Running" -> "Faulted" [label="致命障害検出"];
  "Runnable" -> "Faulted" [label="致命障害検出"];
  "Quiesced" -> "Faulted" [label="致命障害検出"];
  "Faulted" -> "Runnable" [label="PARTITION_RECOVER"];
  "Created" -> "Destroyed" [label="PARTITION_DESTROY"];
  "Measured" -> "Destroyed" [label="PARTITION_DESTROY"];
  "Loaded" -> "Destroyed" [label="PARTITION_DESTROY"];
  "Runnable" -> "Destroyed" [label="PARTITION_DESTROY"];
  "Running" -> "Destroyed" [label="PARTITION_DESTROY"];
  "Quiesced" -> "Destroyed" [label="PARTITION_DESTROY"];
  "Faulted" -> "Destroyed" [label="PARTITION_DESTROY"];
}
