{
  "goal": "Constrain retained C to tiny hardware-boundary leaves while moving all hypervisor policy and orchestration into Ada/SPARK",
  "authoritative_language": "Ada/SPARK",
  "authoritative_packages": [
    "FBVBS.Commands",
    "FBVBS.Partitions",
    "FBVBS.Logging",
    "FBVBS.Boot",
    "FBVBS.Platform",
    "FBVBS.VMX"
  ],
  "permitted_retained_c": {
    "categories": [
      "VMX instruction wrappers",
      "SVM instruction wrappers",
      "fixed-width CPUID/MSR probe helpers",
      "similarly tiny leaf hardware-boundary code"
    ],
    "rules": [
      "leaf only",
      "no policy decisions",
      "no memory ownership logic",
      "no partition lifecycle logic",
      "no hypercall parsing",
      "fixed integer-only ABI to Ada/SPARK",
      "single-direction safety contract from Ada/SPARK to C leaf"
    ]
  },
  "current_legacy_c_migration_scope": [
    "hypervisor/src/kernel.c",
    "hypervisor/src/partition.c",
    "hypervisor/src/command.c",
    "hypervisor/src/security.c",
    "hypervisor/src/log.c",
    "hypervisor/src/memory.c",
    "hypervisor/src/vm_policy.c",
    "hypervisor/src/vmx.c"
  ],
  "known_current_gap": [
    "hypervisor/src/vm_policy.c still exists as a temporary C mirror of Ada-owned VM exit shaping and should eventually collapse into a leaf-only runtime boundary"
  ],
  "target_split": [
    {
      "legacy_unit": "hypervisor/src/vmx.c",
      "retain_in_c": [
        "future VMX leaf wrappers only",
        "capability probing and fixed-width leaf-exit observation helpers"
      ],
      "move_to_ada_spark": []
    },
    {
      "legacy_unit": "hypervisor/src/vm_policy.c",
      "retain_in_c": [],
      "move_to_ada_spark": [
        "run-loop decision logic",
        "exit classification semantics",
        "fault state transitions",
        "policy-level capability gating"
      ]
  }
  ]
}
